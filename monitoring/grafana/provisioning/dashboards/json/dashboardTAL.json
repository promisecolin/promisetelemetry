      ]
    },
    "panels": [

      {
        "id": 100,
        "type": "text",
        "title": "",
        "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
        "options": {
          "mode": "markdown",
          "content": "# 🛰️ SERVICES\n**Real-time health, latency, and error rate for all 17 microservices**"
        }
      },

      {
        "id": 1,
        "title": "Service Latency — All Services (Live)",
        "description": "Current latency in milliseconds for every microservice. Red threshold at 400ms.",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 2 },
        "targets": [
          {
            "expr": "promisetelemetry_service_latency_ms_milliseconds_sum / promisetelemetry_service_latency_ms_milliseconds_count",
            "legendFormat": "{{ service }}",
            "refId": "A",
            "instant": true
          }
        ],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "min": 0,
            "max": 1000,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "#37872D", "value": null },
                { "color": "#FF9830", "value": 200 },
                { "color": "#C4162A", "value": 400 }
              ]
            },
            "color": { "mode": "thresholds" }
          }
        },
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true,
          "minVizWidth": 8,
          "minVizHeight": 16,
          "valueMode": "color"
        }
      },

      {
        "id": 2,
        "title": "Service Error Rate — All Services (Live)",
        "description": "Current error percentage per microservice. Anything above 5% is critical.",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
        "targets": [
          {
            "expr": "promisetelemetry_service_error_rate_percent",
            "legendFormat": "{{ service }}",
            "refId": "A",
            "instant": true
          }
        ],
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 30,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "#37872D", "value": null },
                { "color": "#FF9830", "value": 2 },
                { "color": "#C4162A", "value": 5 }
              ]
            },
            "color": { "mode": "thresholds" }
          }
        },
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true,
          "minVizWidth": 8,
          "minVizHeight": 16,
          "valueMode": "color"
        }
      },

